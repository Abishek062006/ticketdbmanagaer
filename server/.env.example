PORT=5001
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/conversational_db_manager

OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=60000

# Used to sign/verify login JWTs. Set a long random value in production.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=12h

# Only used on first boot, when no admin account exists yet - creates the
# reserved "employees" identity table + the first admin row.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me
